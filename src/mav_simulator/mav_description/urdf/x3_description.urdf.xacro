<?xml version="1.0"?>
<!-- X3 UAV quadcopter URDF (matches model.sdf structure for ROS2 robot_state_publisher / RViz).
     Pass name from launch: xacro ... name:=X3 (default: X3) -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="$(arg name)">
  <xacro:arg name="name" default="X3"/>
  <xacro:property name="prefix" value="$(arg name)"/>

  <link name="${prefix}/base_footprint"/>

  <joint name="${prefix}/base_footprint_joint" type="fixed">
    <parent link="${prefix}/base_footprint"/>
    <child link="${prefix}/base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Base link: X3 body mesh (matches model.sdf: box 0.47 x 0.47 x 0.11 m, mass 1.5 kg) -->
  <link name="${prefix}/base_link">
    <visual>
      <geometry>
        <mesh
          filename="package://mav_description/models/x3/meshes/x3.dae"
          scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="x3_grey">
        <color rgba="0.4 0.4 0.4 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.47 0.47 0.11"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.0347563" iyy="0.07" izz="0.0977" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Rotor 0: front-right (x,y = 0.13 -0.22), ccw (matches model.sdf) -->
  <link name="${prefix}/rotor_0">
    <visual>
      <geometry>
        <mesh
          filename="package://mav_description/models/x3/meshes/propeller_ccw.dae"
          scale="0.1 0.1 0.1"/>
      </geometry>
      <material name="rotor_grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.005"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="9.75e-7" iyy="4.17041e-5" izz="4.26041e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="${prefix}/rotor_0_joint" type="revolute">
    <parent link="${prefix}/base_link"/>
    <child link="${prefix}/rotor_0"/>
    <origin xyz="0.13 -0.22 0.023" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1e16" upper="1e16" effort="100" velocity="1000"/>
  </joint>

  <!-- Rotor 1: rear-left (-0.13 0.2), ccw -->
  <link name="${prefix}/rotor_1">
    <visual>
      <geometry>
        <mesh
          filename="package://mav_description/models/x3/meshes/propeller_ccw.dae"
          scale="0.1 0.1 0.1"/>
      </geometry>
      <material name="rotor_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.005"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="9.75e-7" iyy="4.17041e-5" izz="4.26041e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="${prefix}/rotor_1_joint" type="revolute">
    <parent link="${prefix}/base_link"/>
    <child link="${prefix}/rotor_1"/>
    <origin xyz="-0.13 0.2 0.023" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1e16" upper="1e16" effort="100" velocity="1000"/>
  </joint>

  <!-- Rotor 2: rear-right (0.13 0.22), cw -->
  <link name="${prefix}/rotor_2">
    <visual>
      <geometry>
        <mesh
          filename="package://mav_description/models/x3/meshes/propeller_cw.dae"
          scale="0.1 0.1 0.1"/>
      </geometry>
      <material name="rotor_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.005"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="9.75e-7" iyy="4.17041e-5" izz="4.26041e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="${prefix}/rotor_2_joint" type="revolute">
    <parent link="${prefix}/base_link"/>
    <child link="${prefix}/rotor_2"/>
    <origin xyz="0.13 0.22 0.023" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1e16" upper="1e16" effort="100" velocity="1000"/>
  </joint>

  <!-- Rotor 3: front-left (-0.13 -0.22), cw -->
  <link name="${prefix}/rotor_3">
    <visual>
      <geometry>
        <mesh
          filename="package://mav_description/models/x3/meshes/propeller_cw.dae"
          scale="0.1 0.1 0.1"/>
      </geometry>
      <material name="rotor_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.005"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="9.75e-7" iyy="4.17041e-5" izz="4.26041e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="${prefix}/rotor_3_joint" type="revolute">
    <parent link="${prefix}/base_link"/>
    <child link="${prefix}/rotor_3"/>
    <origin xyz="-0.13 -0.22 0.023" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1e16" upper="1e16" effort="100" velocity="1000"/>
  </joint>
</robot>
